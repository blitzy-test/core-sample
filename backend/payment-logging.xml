<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Import core logging configuration -->
    <include resource="logback.xml"/>

    <!-- Status listener to suppress internal logback messages -->
    <statusListener class="ch.qos.logback.core.status.NopStatusListener" />

    <!-- Define MDC property names for payment context -->
    <property name="PAYMENT_MDC_TRANSACTION_ID" value="transaction_id"/>
    <property name="PAYMENT_MDC_MERCHANT_ID" value="merchant_id"/>
    <property name="PAYMENT_MDC_AMOUNT" value="amount"/>
    <property name="PAYMENT_MDC_CURRENCY" value="currency"/>
    <property name="PAYMENT_MDC_STATUS" value="payment_status"/>
    <property name="PAYMENT_MDC_PREVIOUS_STATUS" value="previous_status"/>
    <property name="PAYMENT_MDC_NEW_STATUS" value="new_status"/>
    <property name="PAYMENT_MDC_PROCESSING_STAGE" value="processing_stage"/>
    <property name="PAYMENT_MDC_CORRELATION_ID" value="correlation_id"/>
    <property name="PAYMENT_MDC_EXECUTION_TIME" value="execution_time_ms"/>
    <property name="PAYMENT_MDC_USER_ID" value="user_id"/>
    <property name="PAYMENT_MDC_ERROR_CODE" value="error_code"/>
    <property name="PAYMENT_MDC_PAYMENT_TYPE" value="payment_type"/>

    <!-- JSON encoder for structured payment logs -->
    <appender name="PAYMENT_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>true</includeContext>
            <customFields>{"application":"payment-service"}</customFields>
            <!-- Include MDC fields for payment context -->
            <includeMdcKeyName>${PAYMENT_MDC_TRANSACTION_ID}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_MERCHANT_ID}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_AMOUNT}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_CURRENCY}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_STATUS}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_PREVIOUS_STATUS}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_NEW_STATUS}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_PROCESSING_STAGE}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_CORRELATION_ID}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_EXECUTION_TIME}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_USER_ID}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_ERROR_CODE}</includeMdcKeyName>
            <includeMdcKeyName>${PAYMENT_MDC_PAYMENT_TYPE}</includeMdcKeyName>
            <!-- PII masking for sensitive data -->
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
        </encoder>
    </appender>

    <!-- File appender for payment audit trail -->
    <appender name="PAYMENT_AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/payment-audit.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/payment-audit.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>true</includeContext>
            <customFields>{"log_type":"payment_audit"}</customFields>
            <!-- Include all MDC fields for comprehensive audit -->
            <includeMdc>true</includeMdc>
        </encoder>
    </appender>

    <!-- Async wrapper for payment audit file to improve performance -->
    <appender name="ASYNC_PAYMENT_AUDIT" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="PAYMENT_AUDIT_FILE" />
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>true</includeCallerData>
        <neverBlock>false</neverBlock>
    </appender>

    <!-- PII masking filter for sensitive payment data -->
    <turboFilter class="ch.qos.logback.classic.turbo.MDCFilter">
        <MDCKey>masked_logging</MDCKey>
        <Value>true</Value>
        <OnMatch>ACCEPT</OnMatch>
    </turboFilter>

    <!-- Custom converter for masking sensitive payment data -->
    <conversionRule conversionWord="maskedMsg" 
                   converterClass="io.briklabs.sample.payments.logging.PiiMaskingConverter" />

    <!-- Payment transaction processing logger -->
    <logger name="io.briklabs.sample.payments.service.TransactionProcessor" level="${log.payment.processor.level:-INFO}" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
        <appender-ref ref="ASYNC_PAYMENT_AUDIT" />
    </logger>

    <!-- Payment state transition logger -->
    <logger name="io.briklabs.sample.payments.service.StateManager" level="${log.payment.state.level:-INFO}" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
        <appender-ref ref="ASYNC_PAYMENT_AUDIT" />
    </logger>

    <!-- Payment REST API logger -->
    <logger name="io.briklabs.sample.payments.rest" level="${log.payment.rest.level:-INFO}" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
    </logger>

    <!-- Payment data access layer logger -->
    <logger name="io.briklabs.sample.payments.data" level="${log.payment.data.level:-INFO}" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
    </logger>

    <!-- HikariCP connection pool logger for payment operations -->
    <logger name="com.zaxxer.hikari" level="${log.hikari.level:-INFO}" />
    <logger name="com.zaxxer.hikari.pool.HikariPool" level="${log.hikari.pool.level:-INFO}" />
    <logger name="com.zaxxer.hikari.pool.PoolBase" level="${log.hikari.pool.level:-INFO}" />
    <logger name="com.zaxxer.hikari.HikariConfig" level="${log.hikari.config.level:-INFO}" />
    <logger name="com.zaxxer.hikari.pool.ProxyConnection" level="${log.hikari.connection.level:-INFO}" />

    <!-- Root logger for all payment components -->
    <logger name="io.briklabs.sample.payments" level="${log.payment.level:-INFO}" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
    </logger>

    <!-- Error logger for payment operations with enhanced context -->
    <logger name="io.briklabs.sample.payments.error" level="ERROR" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
        <appender-ref ref="ASYNC_PAYMENT_AUDIT" />
    </logger>

    <!-- Correlation tracking for asynchronous payment operations -->
    <logger name="io.briklabs.sample.payments.async" level="${log.payment.async.level:-INFO}" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
    </logger>

    <!-- Payment security and access control logging -->
    <logger name="io.briklabs.sample.payments.security" level="${log.payment.security.level:-INFO}" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
        <appender-ref ref="ASYNC_PAYMENT_AUDIT" />
    </logger>

    <!-- Payment validation logger -->
    <logger name="io.briklabs.sample.payments.validation" level="${log.payment.validation.level:-INFO}" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
    </logger>

    <!-- Payment metrics and performance logging -->
    <logger name="io.briklabs.sample.payments.metrics" level="${log.payment.metrics.level:-INFO}" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
    </logger>

    <!-- Payment database query performance logging -->
    <logger name="io.briklabs.sample.payments.data.query" level="${log.payment.query.level:-INFO}" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
    </logger>

    <!-- Payment event tracking logger -->
    <logger name="io.briklabs.sample.payments.events" level="${log.payment.events.level:-INFO}" additivity="false">
        <appender-ref ref="PAYMENT_JSON" />
        <appender-ref ref="ASYNC_PAYMENT_AUDIT" />
    </logger>

    <!-- Turbo filter for correlation ID tracking across threads -->
    <turboFilter class="io.briklabs.sample.payments.logging.CorrelationIdTurboFilter">
        <OnMissingCorrelationId>NEUTRAL</OnMissingCorrelationId>
    </turboFilter>

    <!-- MDC cleanup filter to prevent memory leaks -->
    <filter class="io.briklabs.sample.payments.logging.MDCCleanupFilter" />
</configuration>